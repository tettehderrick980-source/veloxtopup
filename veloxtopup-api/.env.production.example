# =====================================================
# VELOXTOPUP API - PRODUCTION ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit this file to version control!
# =====================================================

# ═════════════════════════════════════════════════════
# SERVER CONFIGURATION
# ═════════════════════════════════════════════════════
NODE_ENV=production
PORT=5000
API_VERSION=v1

# ═════════════════════════════════════════════════════
# SUPABASE CONFIGURATION (REQUIRED)
# ═════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs... (get from Supabase Dashboard > Settings > API)

# ═════════════════════════════════════════════════════
# JWT CONFIGURATION (IMPORTANT - Generate secure keys!)
# ═════════════════════════════════════════════════════
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
JWT_EXPIRES_IN=7d

# ═════════════════════════════════════════════════════
# PAYSTACK CONFIGURATION (REQUIRED FOR PAYMENTS)
# ═════════════════════════════════════════════════════
PAYSTACK_SECRET_KEY=sk_live_your_actual_key
PAYSTACK_PUBLIC_KEY=pk_live_your_actual_key
PAYSTACK_WEBHOOK_SECRET=whsec_get_from_paystack_dashboard
PAYSTACK_WEBHOOK_TOKEN=wh_tok_generate_a_secure_token

# ═════════════════════════════════════════════════════
# GHDATACONNECT API (REQUIRED FOR AIRTIME)
# ═════════════════════════════════════════════════════
GH_DATACONNECT_API_KEY=your_api_key_from_ghdataconnect
GH_DATACONNECT_API_URL=https://ghdataconnect.com/api
GH_DATACONNECT_WEBHOOK_TOKEN=ghd_tok_generate_a_secure_token

# ═════════════════════════════════════════════════════
# EMAIL/SMTP CONFIGURATION (REQUIRED FOR NOTIFICATIONS)
# ═════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_16_char_app_password (NOT your regular password!)
SMTP_FROM=noreply@veloxtopup.com

# For Gmail, use App Password: https://support.google.com/accounts/answer/185833

# ═════════════════════════════════════════════════════
# CORS CONFIGURATION (CRITICAL FOR SECURITY)
# ═════════════════════════════════════════════════════
CORS_ORIGIN=https://veloxtopup.shop  # Your production frontend URL

# ═════════════════════════════════════════════════════
# RATE LIMITING
# ═════════════════════════════════════════════════════
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100

# ═════════════════════════════════════════════════════
# LOGGING
# ═════════════════════════════════════════════════════
LOG_LEVEL=error  # Use 'error' in production to reduce log volume

# ═════════════════════════════════════════════════════
# OPTIONAL: REDIS (Only if using Bull queue)
# ═════════════════════════════════════════════════════
REDIS_URL=redis://username:password@host:port

# ═════════════════════════════════════════════════════
# SECURITY CHECKLIST
# ═════════════════════════════════════════════════════
# □ Change JWT_SECRET to a strong random string (use: node -e "console.log(crypto.randomBytes(32).toString('hex'))")
# □ Use Paystack LIVE keys (sk_live_..., not sk_test_...)
# □ Update CORS_ORIGIN to your exact production domain
# □ Generate unique webhook tokens
# □ Use App Password for Gmail, not your regular password
# □ Keep SUPABASE_SERVICE_ROLE_KEY secret - never expose it!